{
  "id": "refactor-task",
  "name": "Refactor Task",
  "description": "Change internal structure while preserving external behavior.",
  "caps": {"max_agents": 5, "max_parallel": 3},
  "agents": ["conductor", "planner", "worker", "critic", "acceptance_gate"],
  "handoffs": [
    {"from": "conductor", "to": "planner"},
    {"from": "planner", "to": "worker"},
    {"from": "worker", "to": "critic"},
    {"from": "critic", "to": "acceptance_gate"}
  ],
  "required_artifacts": [
    "artifacts/refactor-plan.md",
    "artifacts/behavior-baseline.json",
    "artifacts/behavior-diff.json",
    "artifacts/refactor-coverage.json",
    "artifacts/api-surface-diff.json",
    "artifacts/refactor-structure.json",
    "artifacts/complexity-report.json",
    "artifacts/perf-budget.json",
    "artifacts/refactor-resistance.json",
    "artifacts/test-result.json",
    "artifacts/critic-review.md",
    "artifacts/acceptance-result.json"
  ],
  "acceptance_gates": ["behavior-baseline-pre-edit", "behavior-baseline-deterministic", "behavior-diff-clean", "changed-lines-covered", "public-api-stable-or-justified", "refactor-type-structure", "complexity-not-worse", "perf-budget", "refactor-regression-resistance", "tests-pass", "scope-contained", "handoffs-valid"],
  "deterministic_checks": [
    {"name": "behavior-baseline", "command": "python maw-tools/behavior_baseline.py capture --manifest <behavior-manifest.json> --output artifacts/behavior-baseline.json"},
    {"name": "behavior-diff", "command": "python maw-tools/behavior_baseline.py verify --manifest <behavior-manifest.json> --baseline artifacts/behavior-baseline.json --output artifacts/behavior-diff.json"},
    {"name": "refactor-coverage", "command": "python maw-tools/behavior_baseline.py coverage --manifest <behavior-manifest.json> --baseline artifacts/behavior-baseline.json --output artifacts/refactor-coverage.json"},
    {"name": "api-surface-diff", "command": "python maw-tools/behavior_baseline.py api --manifest <behavior-manifest.json> --baseline artifacts/behavior-baseline.json --output artifacts/api-surface-diff.json"},
    {"name": "refactor-structure", "command": "python maw-tools/behavior_baseline.py structure --plan artifacts/refactor-plan.json --manifest <behavior-manifest.json> --output artifacts/refactor-structure.json"},
    {"name": "complexity-report", "command": "python maw-tools/behavior_baseline.py complexity --plan artifacts/refactor-plan.json --manifest <behavior-manifest.json> --baseline artifacts/behavior-baseline.json --output artifacts/complexity-report.json"},
    {"name": "perf-budget", "command": "python maw-tools/behavior_baseline.py perf --plan artifacts/refactor-plan.json --manifest <behavior-manifest.json> --baseline artifacts/behavior-baseline.json --output artifacts/perf-budget.json"},
    {"name": "refactor-resistance", "command": "python maw-tools/behavior_baseline.py resistance --manifest <behavior-manifest.json> --baseline artifacts/behavior-baseline.json --output artifacts/refactor-resistance.json"},
    {"name": "baseline-tests", "command": "python -m pytest -q"},
    {"name": "handoffs", "command": "python maw-tools/validate_handoffs.py <run_dir>"}
  ]
}
