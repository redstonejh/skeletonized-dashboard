{
  "id": "standard-software-task",
  "name": "Standard Software Task",
  "description": "General feature or implementation work with planning, implementation, review, and acceptance.",
  "caps": {"max_agents": 5, "max_parallel": 3},
  "agents": ["conductor", "planner", "worker", "critic", "acceptance_gate"],
  "handoffs": [
    {"from": "conductor", "to": "planner"},
    {"from": "planner", "to": "worker"},
    {"from": "worker", "to": "critic"},
    {"from": "critic", "to": "acceptance_gate"}
  ],
  "required_artifacts": [
    "artifacts/plan.md",
    "artifacts/test-result.json",
    "artifacts/critic-review.md",
    "artifacts/acceptance-result.json"
  ],
  "acceptance_gates": ["tests-pass", "requirements-covered", "handoffs-valid"],
  "deterministic_checks": [
    {"name": "unit-tests", "command": "py -m unittest discover -s tests"},
    {"name": "handoffs", "command": "py maw-tools/validate_handoffs.py <run_dir>"}
  ]
}
