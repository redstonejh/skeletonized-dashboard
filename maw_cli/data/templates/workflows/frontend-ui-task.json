{
  "id": "frontend-ui-task",
  "name": "Front-End UI Task",
  "description": "Build or audit front-end UI files with deterministic static checks for accessibility, contrast, budgets, links, and markup.",
  "caps": {"max_agents": 13, "max_parallel": 3},
  "agents": ["conductor", "planner", "ui_builder", "change_verifier", "a11y_auditor", "responsive_checker", "perf_budgeter", "markup_validator", "style_drift_auditor", "visual_verifier", "ux_critic", "critic", "acceptance_gate"],
  "handoffs": [
    {"from": "conductor", "to": "planner"},
    {"from": "planner", "to": "ui_builder"},
    {"from": "ui_builder", "to": "change_verifier"},
    {"from": "change_verifier", "to": "a11y_auditor"},
    {"from": "a11y_auditor", "to": "responsive_checker"},
    {"from": "responsive_checker", "to": "perf_budgeter"},
    {"from": "perf_budgeter", "to": "markup_validator"},
    {"from": "markup_validator", "to": "style_drift_auditor"},
    {"from": "style_drift_auditor", "to": "visual_verifier"},
    {"from": "visual_verifier", "to": "ux_critic"},
    {"from": "ux_critic", "to": "critic"},
    {"from": "critic", "to": "acceptance_gate"}
  ],
  "required_artifacts": [
    "artifacts/ui-build.md",
    "artifacts/change-verification.json",
    "artifacts/style-extraction.json",
    "artifacts/a11y-audit.json",
    "artifacts/contrast-check.json",
    "artifacts/responsive-check.md",
    "artifacts/perf-budget.json",
    "artifacts/markup-validation.json",
    "artifacts/link-check.json",
    "artifacts/style-drift-audit.json",
    "artifacts/visual-verification.md",
    "artifacts/ux-critique.md",
    "artifacts/acceptance-result.json"
  ],
  "acceptance_gates": ["requested-change-present", "no-design-token-drift", "a11y-static-pass", "contrast-pass", "budget-pass", "links-pass", "markup-pass", "advisory-ux-recorded"],
  "deterministic_checks": [
    {"name": "contrast", "command": "uv run python maw-tools/web_checks.py contrast --foreground <hex> --background <hex>"},
    {"name": "a11y", "command": "uv run python maw-tools/web_checks.py a11y <html>"},
    {"name": "budget", "command": "uv run python maw-tools/web_checks.py budget <html> --max-bytes <n> --max-elements <n> --max-assets <n>"},
    {"name": "links", "command": "uv run python maw-tools/web_checks.py links <html>"},
    {"name": "markup", "command": "uv run python maw-tools/web_checks.py markup <html>"},
    {"name": "style", "command": "uv run python maw-tools/web_checks.py style <css> --selector <selector> --property <property>"},
    {"name": "changed", "command": "uv run python maw-tools/web_checks.py changed --before <before.css> --after <after.css> --selector <selector> --property <property> --expected <value>"},
    {"name": "tokens", "command": "uv run python maw-tools/web_checks.py tokens --token-file <design-tokens.json> <css...>"},
    {"name": "apply-design", "command": "maw apply-design liquid-glass <target> --output artifacts/apply-design.json"},
    {"name": "design-parity", "command": "maw design-parity <target> --output artifacts/design-parity.json"},
    {"name": "handoffs", "command": "uv run python maw-tools/validate_handoffs.py <run_dir>"}
  ]
}
